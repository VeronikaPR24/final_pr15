<Application x:Class="final_pr15.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:final_pr15"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#00c4b4"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#00b4c4"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#dfeaeb"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#ffd129"/>
    </Application.Resources>
</Application>
