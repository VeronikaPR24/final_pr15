<Page x:Class="final_pr15.Pages.RegistrPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:final_pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrPage"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <TextBlock Text="Вход в приложение" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="40"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Вход для менеджера" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <PasswordBox x:Name="PinBox" Height="40" Margin="0,0,0,10"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" HorizontalAlignment="Center" Margin="5" Visibility="Collapsed"/>
            <Button Content="Войти как менеджер" Background="{StaticResource SecondaryBrush}" Foreground="White" Height="50" FontSize="16" Click="AdminLogin_Click"/>
            <Button Content="Войти как посетитель" Background="{StaticResource PrimaryBrush}" Foreground="White" Height="50" FontSize="16" Margin="0,10,0,20" Click="GuestLogin_Click"/>
        </StackPanel>
    </Grid>
</Page>
