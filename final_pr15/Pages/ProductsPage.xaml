<Page x:Class="final_pr15.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:final_pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductsPage"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2">
            <TextBlock Text="Каталог товаров" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Выход" Click="Logout_Click" Height="30" Width="100" Background="{StaticResource SecondaryBrush}" Foreground="White"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5,0,5">
            <TextBlock Text="Поиск" Margin="5, 0, 0, 5"/>
            <TextBox x:Name="SearchBox" Margin="5, 0" TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" Padding="10">
                    <StackPanel>
                        <StackPanel>
                            <TextBlock Text="Сортировка" Margin="0,0,0,5"/>
                            <ComboBox x:Name="SortComboBox" SelectionChanged="SortComboBox_SelectionChanged">
                                <ComboBoxItem Tag="Name">По названию</ComboBoxItem>
                                <ComboBoxItem Tag="PriceAsc">Цена по возрастанию</ComboBoxItem>
                                <ComboBoxItem Tag="PriceDesc">Цена по убыванию</ComboBoxItem>
                                <ComboBoxItem Tag="StockAsc">Количество по возрастанию</ComboBoxItem>
                                <ComboBoxItem Tag="StockDesc">Количество по убыванию</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Text="Категория"/>
                        <ComboBox x:Name="CategoryFilter" SelectionChanged="CategoryFilter_Changed">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Бренд" Margin="0,10,0,0"/>
                        <ComboBox x:Name="BrandFilter" SelectionChanged="BrandFilter_Changed">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Цена" Margin="0,10,0,0"/>
                        <TextBox x:Name="PriceFrom"/>
                        <TextBox x:Name="PriceTo" Margin="0,5,0,0"/>
                        <Button x:Name="ApplyPriceFilter" Content="Применить фильтр цен" Click="ApplyPriceFilter_Click" Margin="0,5,0,0" Height="25" Background="{StaticResource PrimaryBrush}" Foreground="White"/>
                        <Button Content="Сбросить фильтры" Click="ResetFilters_Click" Background="{StaticResource SecondaryBrush}" Foreground="White" Margin="0,5,0,0" Height="25"/>
                    </StackPanel>
                </Border>

                <Border x:Name="AdminPanel" Background="White" Padding="10" Margin="0,10,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Управление" Margin="0,0,0,10"/>
                        <Button Content="Добавить товар" Click="AddProduct_Click" Background="{StaticResource PrimaryBrush}" Foreground="White"/>
                        <Button Content="Редактировать товар" Click="EditSelectedProduct_Click" Background="{StaticResource SecondaryBrush}" Foreground="White" Margin="0,5,0,0" IsEnabled="False" x:Name="EditProductButton"/>
                        <Button Content="Удалить товар" Click="DeleteSelectedProduct_Click" Background="{StaticResource SecondaryBrush}" Foreground="White" Margin="0,5,0,0" IsEnabled="False" x:Name="DeleteProductButton"/>
                        <Button Content="Категории" Click="ManageCategories_Click" Margin="0,5,0,0" Background="{StaticResource SecondaryBrush}" Foreground="White"/>
                        <Button Content="Бренды" Click="ManageBrands_Click" Margin="0,5,0,0" Background="{StaticResource SecondaryBrush}" Foreground="White"/>
                        <Button Content="Теги" Click="ManageTags_Click" Margin="0,5,0,0" Background="{StaticResource SecondaryBrush}" Foreground="White"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="White" Padding="5" Margin="5, 0">
                        <TextBlock x:Name="TotalText" Text="Всего: "/>
                    </Border>
                    <Border Background="White" Padding="5" >
                        <TextBlock x:Name="FilteredText" Text="Показано: "/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <ListBox x:Name="ProductsList" Grid.Row="2" Grid.Column="1" SelectionChanged="ProductsList_SelectionChanged" Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ProductBorder" Background="White" Width="315" Height="170" BorderThickness="1" BorderBrush="Transparent" Padding="10" Tag="{Binding Id}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding Name}" FontSize="16" Margin="0,0,0,5"/>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="⭐" Foreground="Gold" FontSize="12"/>
                                <TextBlock Text="{Binding Rating}" Margin="3,0,0,0" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Category.Name, StringFormat='Категория: '}" Foreground="Black" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Description, StringFormat='Описание: '}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" FontSize="12" Margin="0,0,0,8" Tag="{Binding Id}"/>

                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Остаток: " Foreground="Black" FontSize="12"/>
                                <TextBlock Text="{Binding Stock}" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text=" Цена: " Foreground="Black" FontSize="12"/>
                                <TextBlock Text="{Binding Price}" Foreground="Black" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Stock}" Value="0">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="1">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="2">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="3">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="4">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="5">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="6">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="7">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="8">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="9">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Stock}" Value="10">
                            <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>