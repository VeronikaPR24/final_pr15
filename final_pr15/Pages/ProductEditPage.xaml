<Page x:Class="final_pr15.Pages.ProductEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:final_pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductEditPage"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавить/изменить товар" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
        <Label Grid.Row="1" Content="Название товара:" FontWeight="SemiBold" Margin="0,5,0,5"/>
        <TextBox Grid.Row="2" x:Name="NameBox" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <Label Grid.Row="3" Content="Описание:" FontWeight="SemiBold" Margin="0,5,0,5"/>
        <TextBox Grid.Row="4" x:Name="DescriptionBox" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

        <Grid Grid.Row="5" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Label Content="Цена:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <TextBox x:Name="PriceBox" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Label Content="Количество на складе:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <TextBox x:Name="StockBox" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="6" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Label Content="Категория:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <ComboBox x:Name="CategoryBox" DisplayMemberPath="Name" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Label Content="Бренд:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <ComboBox x:Name="BrandBox" DisplayMemberPath="Name" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Label Grid.Row="7" Content="Рейтинг (0-5):" FontWeight="SemiBold" Margin="0,5,0,5"/>
        <TextBox Grid.Row="8" x:Name="RatingBox" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <Label Grid.Row="9" Content="Тег:" FontWeight="SemiBold" Margin="0,10,0,5"/>
        <ComboBox Grid.Row="10" x:Name="TagsBox" DisplayMemberPath="Name" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Click="Save_Click" Background="{StaticResource SecondaryBrush}" Foreground="White" FontSize="15" Width="120" Height="50" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="120" Background="{StaticResource PrimaryBrush}" Foreground="White" FontSize="15" Height="50"/>
        </StackPanel>
    </Grid>
</Page>